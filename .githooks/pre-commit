#!/usr/bin/env bash
#
# Pre-commit hook: block commits containing secrets, API keys, tokens, or PII.
# Install: git config core.hooksPath .githooks
#
# Compatible with macOS (BSD grep) and Linux (GNU grep).
#

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

FOUND=0

# Only scan staged files (added/modified), skip deleted files.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

check_pattern() {
  local label="$1"
  local pattern="$2"

  for file in $STAGED_FILES; do
    # Skip binary files
    if file "$file" 2>/dev/null | grep -q "binary"; then
      continue
    fi

    MATCHES=$(git show ":$file" 2>/dev/null | grep -nE "$pattern" 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
      echo -e "${RED}BLOCKED${NC} Potential secret detected: ${YELLOW}${label}${NC}"
      echo "  File: $file"
      echo "$MATCHES" | head -3 | while read -r line; do
        echo "    $line"
      done
      echo ""
      FOUND=1
    fi
  done
}

# AWS
check_pattern "AWS Access Key" "AKIA[0-9A-Z]{16}"
check_pattern "AWS Secret Key" "aws_secret_access_key[[:space:]]*[=:][[:space:]]*[^[:space:]]+"

# Generic secrets assigned in code
check_pattern "Generic API Key assignment" "(api[_-]?key|apikey)[[:space:]]*[=:][[:space:]]*['\"][A-Za-z0-9_/+.=-]{20,}['\"]"
check_pattern "Generic Secret/Password/Token assignment" "(secret|password|passwd)[[:space:]]*[=:][[:space:]]*['\"][^'\"]{8,}['\"]"

# Private keys
check_pattern "Private Key Block" "-----BEGIN[[:space:]]+(RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----"

# Platform-specific tokens
check_pattern "GitHub Token" "gh[pousr]_[A-Za-z0-9_]{36,}"
check_pattern "Slack Token" "xox[bpoas]-[0-9a-zA-Z-]+"
check_pattern "Google API Key" "AIza[0-9A-Za-z_-]{35}"
check_pattern "Stripe Key" "(sk|pk)_(test|live)_[0-9a-zA-Z]{24,}"
check_pattern "NPM Token" "npm_[A-Za-z0-9]{36}"

# Bearer tokens
check_pattern "Bearer Token" "[Bb]earer[[:space:]]+[A-Za-z0-9_+/.-]{20,}"

if [ "$FOUND" -eq 1 ]; then
  echo -e "${RED}Commit blocked.${NC} Secrets or sensitive data detected in staged files."
  echo ""
  echo "If this is a false positive, you can bypass with:  git commit --no-verify"
  echo "(Use --no-verify sparingly and only when you are certain it is safe.)"
  exit 1
fi

exit 0
